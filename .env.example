# Server Configuration
NODE_ENV=production
PORT=3000

# Authentication (Admin Backdoor)
USER_NAME=seu_usuario
USER_PASSWORD=sua_senha_segura
SESSION_SECRET=troque_por_uma_string_aleatoria_longa

# Database (Postgres — Easypanel)
# Interno (dentro do Easypanel): ferrazpiai_postgres:5432
# Externo (dev local): uyk8ty.easypanel.host:5433
DATABASE_URL=postgres://postgres:SUA_SENHA@ferrazpiai_postgres:5432/ferrazpiai?sslmode=disable

# Google OAuth 2.0 (configurar em console.cloud.google.com)
GOOGLE_CLIENT_ID=seu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback
# Dominios permitidos no OAuth (separados por virgula). Emails fora sao bloqueados.
GOOGLE_ALLOWED_DOMAINS=v4company.com

# API Endpoints (N8N Webhooks)
API_ENDPOINT_CONV_SABER_MONETIZACAO=https://n8n.example.com/webhook/conv-saber-para-monetizacao
API_ENDPOINT_GTM_MOTION=https://n8n.example.com/webhook/gtm-motion
API_ENDPOINT_MARKETING_VENDAS=https://n8n.example.com/webhook/marketing-vendas
API_ENDPOINT_DIAGRAMA_SANKEY=https://n8n.example.com/webhook/raio-x-financeiro
API_ENDPOINT_COMPARATIVO_SQUADS=https://n8n.example.com/webhook/fechamento-mensal
API_ENDPOINT_NPS_SATISFACAO=https://n8n.example.com/webhook/nps-satisfacao

# Webhooks POST (atualizacao manual)
WEBHOOK_POST_GTM_MOTION=https://n8n.example.com/webhook/trigger-gtm-motion
WEBHOOK_POST_MARKETING_VENDAS=https://n8n.example.com/webhook/trigger-marketing-vendas
WEBHOOK_POST_DIAGRAMA_SANKEY=https://n8n.example.com/webhook/trigger-diagrama-sankey
WEBHOOK_POST_TX_CONV_SABER_MONETIZACAO=https://n8n.example.com/webhook/trigger-conv-saber
WEBHOOK_POST_COMPARATIVO_SQUADS=https://n8n.example.com/webhook/trigger-comparativo-squads
WEBHOOK_POST_NPS_SATISFACAO=https://n8n.example.com/webhook/trigger-nps-satisfacao

# N8N — Verificacao de execucao ativa
N8N_CHECK_STATUS_URL=https://n8n.example.com/webhook/check-execution-status

# Cache Configuration (optional)
# CACHE_TTL=300000

# ────────────────────────────────────────────────────────────
# Super Painel — Torre de Controle
# ────────────────────────────────────────────────────────────

# Kommo CRM
KOMMO_BASE_URL=https://edisonv4companycom.kommo.com/api/v4
KOMMO_API_TOKEN=TODO
KOMMO_PIPELINE_SABER_ID=12925780
KOMMO_RATE_LIMIT_PER_SECOND=3

# OpenAI
OPENAI_API_KEY=TODO
OPENAI_MODEL_ANALYSIS=gpt-5.4-mini
OPENAI_MODEL_VISUAL=gpt-5.4
OPENAI_MODEL_NOTE=gpt-5.4-nano
OPENAI_MODEL_EMBEDDING=text-embedding-3-small
OPENAI_MAX_CONCURRENT=3
OPENAI_MAX_RPM=60

# ────────────────────────────────────────────────────────────
# AI Provider abstracao (analise/nota/coordenador sao configuraveis
# pelo admin-owner via UI — ver tc_ai_provider_config). Embedding
# permanece em OpenAI (text-embedding-3-small).
# ────────────────────────────────────────────────────────────

# OpenRouter — recomendado: deepseek/deepseek-v3.2-exp (output $0.41/1M)
OPENROUTER_API_KEY=TODO
OPENROUTER_SITE_URL=https://dashboards.v4ferrazpiai.com.br
OPENROUTER_APP_TITLE=Torre de Controle V4
OPENROUTER_MAX_CONCURRENT=3
OPENROUTER_MAX_RPM=60

# Admin owner — unico email autorizado a conceder/remover a role 'admin'
# e a editar a configuracao de provider IA
ADMIN_OWNER_EMAIL=ferramenta.ferraz@v4company.com

# Fallback (usado somente se a tabela tc_ai_provider_config nao existir ainda):
# AI_PROVIDER=openai
# AI_MODEL_ANALYSIS=gpt-5.4-mini
# AI_MODEL_NOTE=gpt-5.4-nano
# AI_MODEL_COORDINATOR=

# n8n extracao (POST { url, platform } -> { conteudo_full, ... })
N8N_EXTRACT_WEBHOOK_URL=TODO
N8N_MAX_CONCURRENT=2

# Job worker (Postgres queue)
JOB_POLL_INTERVAL=3000
JOB_BATCH_SIZE=2
JOB_MAX_RETRIES=3
JOB_LOCK_TTL_MS=600000

# RAG — 3 camadas com token budget fixo
RAG_MAX_CONTEXT_TOKENS=12000
RAG_LAYER1_BUDGET=2000
RAG_LAYER2_BUDGET=3000
RAG_LAYER2_TOP_K=5
RAG_LAYER3_BUDGET=2000
RAG_LAYER3_TOP_K=5
RAG_LAYER4_BUDGET=1500

# Analise semanal de colaboradores (cron UTC-3)
COLLAB_ANALYSIS_CRON=0 3 * * 0
COLLAB_ANALYSIS_MODEL=gpt-5.4-mini

# Sync Kommo automatico (intervalo em minutos, 0 desativa)
TC_SYNC_CRON_MINUTES=60
